{
  "run_name": "tracelock-dream-math-code",
  "max_steps": 36000,
  "train_batch_size": 64,
  "eval_batch_size": 64,
  "num_workers": 4,
  "learning_rate": 0.0001,
  "weight_decay": 0.01,
  "max_grad_norm": 1.0,
  "lr_reduce_patience": 4,
  "early_stop_patience": 8,
  "d_model": 4096,
  "model_type": "transformer",
  "d_tracelock": 256,
  "d_tracelock_delta": 32,
  "d_x": 384,
  "num_encoder_layers": 5,
  "num_attention_heads": 8,
  "encoder_ffn_dim": 768,
  "dropout": 0.1,
  "max_gen_len": 256,
  "use_position_encoding": true,
  "use_state_encoding": false,
  "use_dynamic_threshold": true,
  "dynamic_threshold_decision_only": true,
  "target_mask_prob": 0.0,
  "target_mask_keep_loss_weight": 1.0,
  "input_noise_ratio": 0.0,
  "feature_noise_snr_db": 10.0,
  "feature_noise_apply_probability": 0.0,
  "enable_random_crop": true,
  "random_crop_min_ratio": 0.25,
  "random_crop_max_ratio": 1.0,
  "random_crop_apply_to_val": false,
  "val_threshold_scan_ratio": 0.1,
  "val_threshold_scan_metric": "f1",
  "val_state2_only": true,
  "two_pass_reweight": false,
  "token_class_balance": false,
  "negative_loss_weight": 2.0,
  "frontier_positive_bias": true,
  "frontier_positive_bias_strength": 0.5,
  "threshold_center_loss_weight": 0.001,
  "rollout_proxy_threshold": 0.99
}

